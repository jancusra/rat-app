# Central configuration for the SQL Server database used by docker compose.
# These defaults make "docker compose up" work right after cloning.
# Override by editing this file or by exporting the variable in your shell.
#
# DB_HOST is the compose service name used for container-to-container
# connections. From your own machine (e.g. SSMS) connect to: localhost,${DB_PORT}
DB_HOST=db
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=Local456***
DB_NAME=TestApi

# Secret key used to sign JWT auth tokens. The value below is a development
# default so "docker compose up" works right after cloning. CHANGE IT for any
# real deployment (must be at least 32 characters). Rotating the key = set a new
# value here and restart; all previously issued tokens become invalid.
JWT_SECRET_KEY=dev-only-change-me-please-0123456789abcdef0123456789

# Explicit browser origins allowed to call the API with the auth cookie, when
# the frontend is served from a different origin than the API. Comma-separated,
# no wildcard (the CORS spec forbids "*" with credentials). Takes precedence
# over CORS_ALLOW_PRIVATE_NETWORK below. Use this for a real (HTTPS) deployment.
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# When CORS_ALLOWED_ORIGINS is empty, allow ANY localhost/LAN origin to call the
# API with credentials (localhost, 127.x, 10.x, 172.16-31.x, 192.168.x). This is
# what makes a single "docker compose up" work both on http://localhost:3000 and
# from another PC at http://<this-host-LAN-IP>:3000 with no per-IP config.
# Each origin is reflected individually (no wildcard), and arbitrary public
# origins are still rejected. Trusted local networks only — set to false and use
# CORS_ALLOWED_ORIGINS for a public/HTTPS deployment.
CORS_ALLOW_PRIVATE_NETWORK=true

# Auth cookie "Secure" flag. A Secure cookie is only kept by the browser over
# HTTPS, so it must be false to log in over plain HTTP (localhost or LAN IP
# without TLS) — which is the default here so the LAN/localhost setup above just
# works. Set to true for any HTTPS deployment. (SameSite stays "Lax", which is
# fine because the frontend and API share the same host; SameSite ignores port.)
COOKIE_SECURE=false
