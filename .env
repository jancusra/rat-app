# Central configuration for the SQL Server database used by docker compose.
# These defaults make "docker compose up" work right after cloning.
# Override by editing this file or by exporting the variable in your shell.
#
# DB_HOST is the compose service name used for container-to-container
# connections. From your own machine (e.g. SSMS) connect to: localhost,${DB_PORT}
DB_HOST=db
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=Local456***
DB_NAME=TestApi

# Secret key used to sign JWT auth tokens. The value below is a development
# default so "docker compose up" works right after cloning. CHANGE IT for any
# real deployment (must be at least 32 characters). Rotating the key = set a new
# value here and restart; all previously issued tokens become invalid.
JWT_SECRET_KEY=dev-only-change-me-please-0123456789abcdef0123456789

# Origins allowed to call the API from a browser with the auth cookie, when the
# frontend is served from a different origin than the API (e.g. the React app on
# its own host/port instead of behind a shared reverse proxy). Comma-separated
# for multiple, no wildcard (the CORS spec forbids "*" with credentials). Leave
# empty for same-origin / reverse-proxy deployments, which need no CORS.
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=
